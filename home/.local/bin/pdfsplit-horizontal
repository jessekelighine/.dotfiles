#!/usr/bin/env bash

[[ $# -lt 1 ]] && {
	cat << EOF >&2
usage: $(basename "$0") [input.pdf] [output.pdf]
description:
	+---------------+       +------------+------------+
	|               |       |            |            |
	|     input     |  -->  | output p.1 | output p.2 |
	|               |       |            |            |
	+---------------+       +------------+------------+
EOF
	exit 1
}

mutool poster -x 2 "$1" "$2"
