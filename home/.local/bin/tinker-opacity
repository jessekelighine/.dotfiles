#!/usr/bin/env bash

config="$HOME/.config/kitty/kitty.conf"
original=$(awk '/^background_opacity/ { print $2; exit }' "$config" | xargs)

message () {
	local bold; bold=$(tput bold)
	local norm; norm=$(tput sgr0)
	local usage; usage="${bold}USAGE${norm}"
	local command; command="${bold}$(basename "$0")${norm}"
	local description; description="${bold}DESCRIPTION${norm}"
	local options; options="${bold}OPTIONS${norm}"
	cat << EOF
${usage}: ${command} [options]
${description}:
	Modify kitty terminal background opacity. After running
	this command, do "CMD CTRL COMMA" to reload kitty config.
${options}:
	set      [VALUE]   set opacity value 
	increase [VALUE]   increase opacity value
	decrease [VALUE]   decrease opacity value
	value              print opacity value (current: $original)
EOF
}

modify () {
	printf "/^background_opacity\ns/$original/$1\nwq\n" | ed -s "$config" &>/dev/null
}

[[ $# -lt 1 || $# -gt 2 ]] && {
	message
	exit 0
}

### Sub-commands ##############################################################

pattern="^$1"

[[ "set" =~ $pattern ]] && {
	[[ -z "$2" ]] && message >&2 && exit 1
	bc_command="x=$2;if(x>1){x=1}else if(x<0){x=0};x"
	modify $(bc <<< "$bc_command" | xargs printf "%1.2f")
	exit 0
}

[[ "decrease" =~ $pattern ]] && {
	[[ -n "$2" ]] && increment="$2"
	bc_command="x=$original+${increment:-0.1};if(x>1)x=1;x"
	modify $(bc <<< "$bc_command" | xargs printf "%1.2f")
	exit 0
}

[[ "increase" =~ $pattern ]] && {
	[[ -n "$2" ]] && increment="$2"
	bc_command="x=$original-${increment:-0.1};if(x<0)x=0;x"
	modify $(bc <<< "$bc_command" | xargs printf "%1.2f")
	exit 0
}

[[ "value" =~ $pattern ]] && {
	echo "$original"
	exit 0
}

message >&2
exit 1
